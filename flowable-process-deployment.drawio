        <mxCell id="e-s8-s9" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#1F2937;strokeWidth=2;endArrow=classic;fontSize=10;fontColor=#475569;labelBackgroundColor=#FAFAFA;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="s8-deploy-prod" target="s9-autodeploy">
          <mxGeometry relative="1" as="geometry">
