        <mxCell id="e-evolution-loop-label" value="🔄  Nouvelle évolution&#xa;(cf. encart à droite pour les points d'attention)" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=11;fontColor=#854D0E;labelBackgroundColor=#FEF9C3;fontStyle=1;" connectable="0" vertex="1" parent="e-evolution-loop">
          <mxGeometry x="-0.5" y="0" relative="1" as="geometry">
