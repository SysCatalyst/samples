        <mxCell id="s4-test" value="&lt;b&gt;④ Tests unitaires&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:10px&quot;&gt;&lt;span style=&quot;font-family:monospace&quot;&gt;flowable-spring-boot&lt;br/&gt;-starter-test&lt;/span&gt;&lt;br/&gt;H2 in-memory, @Deployment&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1D4ED8;strokeWidth=2;fontSize=11;fontColor=#1E40AF;align=center;verticalAlign=middle;arcSize=10;" vertex="1" parent="1">
