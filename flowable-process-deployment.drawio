        <mxCell id="e-s8-s9-label" value="démarrage de l'app" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;fontColor=#475569;labelBackgroundColor=#FAFAFA;fontStyle=2;" connectable="0" vertex="1" parent="e-s8-s9">
          <mxGeometry x="-0.6" relative="1" as="geometry">
            <mxPoint as="offset" />
