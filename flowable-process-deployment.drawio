        <mxCell id="e-s7gw-back" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#DC2626;strokeWidth=1.5;endArrow=classic;dashed=1;dashPattern=4 2;fontSize=10;fontColor=#DC2626;labelBackgroundColor=#FAFAFA;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="s7-gateway" target="s3-integrate">
