        <!-- Evolution loop arrow : End -> back to Modélisation -->
        <mxCell id="e-evolution-loop" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#CA8A04;strokeWidth=2;endArrow=classic;dashed=1;dashPattern=8 4;fontSize=11;fontColor=#854D0E;labelBackgroundColor=#FAFAFA;fontStyle=1;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;curved=1;" edge="1" parent="1" source="end-event" target="s1-model">
