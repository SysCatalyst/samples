          </mxGeometry>
        </mxCell>

        <!-- Gateway YES -> Deploy prod -->
        <mxCell id="e-s7gw-s8" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#15803D;strokeWidth=2;endArrow=classic;fontSize=10;fontColor=#15803D;labelBackgroundColor=#FAFAFA;" edge="1" parent="1" source="s7-gateway" target="s8-deploy-prod">
