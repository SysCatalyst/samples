        <mxCell id="s5-mr" value="&lt;b&gt;⑤ Merge Request&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:10px&quot;&gt;Code review&lt;br/&gt;+ revue BPMN par 2 devs&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1D4ED8;strokeWidth=2;fontSize=11;fontColor=#1E40AF;align=center;verticalAlign=middle;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="700" y="360" width="180" height="85" as="geometry" />
        </mxCell>

        <!-- ========== CI/CD LANE STEPS ========== -->
        <mxCell id="s6-build" value="&lt;b&gt;⑥ Build &amp; package&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:10px&quot;&gt;&lt;span style=&quot;font-family:monospace&quot;&gt;mvn package&lt;/span&gt;&lt;br/&gt;→ image Docker&lt;br/&gt;BPMN dans le JAR&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#BE185D;strokeWidth=2;fontSize=11;fontColor=#9D174D;align=center;verticalAlign=middle;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="220" y="540" width="180" height="85" as="geometry" />
        </mxCell>

        <mxCell id="s7-recette" value="&lt;b&gt;⑦ Déploiement recette&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:10px&quot;&gt;Iso-prod (même Flowable,&lt;br/&gt;même PostgreSQL)&lt;br/&gt;+ replay cas réels&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#BE185D;strokeWidth=2;fontSize=11;fontColor=#9D174D;align=center;verticalAlign=middle;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="440" y="540" width="200" height="85" as="geometry" />
        </mxCell>

        <!-- Gateway : recette OK ? -->
        <mxCell id="s7-gateway" value="" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#BE185D;strokeWidth=2;fontSize=10;fontColor=#9D174D;" vertex="1" parent="1">
          <mxGeometry x="690" y="555" width="50" height="50" as="geometry" />
        </mxCell>
        <mxCell id="s7-gateway-label" value="Tests OK ?" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#9D174D;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="675" y="610" width="80" height="20" as="geometry" />
        </mxCell>

        <mxCell id="s8-deploy-prod" value="&lt;b&gt;⑧ Déploiement prod&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:10px&quot;&gt;Rolling update K8s&lt;br/&gt;avec smoke tests&lt;br/&gt;rollback automatisé&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#BE185D;strokeWidth=2;fontSize=11;fontColor=#9D174D;align=center;verticalAlign=middle;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="780" y="540" width="180" height="85" as="geometry" />
        </mxCell>

        <!-- ========== RUNTIME LANE STEPS ========== -->
        <mxCell id="s9-autodeploy" value="&lt;b&gt;⑨ Auto-deploy BPMN&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:10px&quot;&gt;Flowable scanne le classpath&lt;br/&gt;&lt;b&gt;→ nouvelle version N en base&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-family:monospace&quot;&gt;ACT_RE_PROCDEF&lt;/span&gt;&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#15803D;strokeWidth=2;fontSize=11;fontColor=#166534;align=center;verticalAlign=middle;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="220" y="715" width="220" height="95" as="geometry" />
        </mxCell>

        <mxCell id="s10-run" value="&lt;b&gt;⑩ Exécution&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:10px&quot;&gt;Nouvelles instances → version N&lt;br/&gt;Anciennes instances → version N-1&lt;br/&gt;pilotage via REST&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#15803D;strokeWidth=2;fontSize=11;fontColor=#166534;align=center;verticalAlign=middle;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="480" y="715" width="220" height="95" as="geometry" />
        </mxCell>

        <mxCell id="s11-monitor" value="&lt;b&gt;⑪ Monitoring&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:10px&quot;&gt;Actuator + Micrometer&lt;br/&gt;instances actives, jobs,&lt;br/&gt;DEADLETTER alerts&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#15803D;strokeWidth=2;fontSize=11;fontColor=#166534;align=center;verticalAlign=middle;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="740" y="715" width="200" height="95" as="geometry" />
        </mxCell>

        <!-- End event -->
        <mxCell id="end-event" value="" style="ellipse;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#15803D;strokeWidth=4;" vertex="1" parent="1">
          <mxGeometry x="990" y="743" width="40" height="40" as="geometry" />
        </mxCell>
        <mxCell id="end-event-label" value="En prod&#xa;&amp; supervisé" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=9;fontColor=#166534;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="970" y="783" width="80" height="30" as="geometry" />
        </mxCell>

        <!-- ========== EVOLUTION LOOP (right side) ========== -->
        <mxCell id="evolution-box" value="&lt;b&gt;🔄  ÉVOLUTION D'UN WORKFLOW EXISTANT&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF9C3;strokeColor=#CA8A04;strokeWidth=2;fontSize=12;fontColor=#854D0E;align=left;verticalAlign=top;spacingTop=10;spacingLeft=15;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="1100" y="160" width="490" height="540" as="geometry" />
        </mxCell>

        <mxCell id="evo-intro" value="Une fois un workflow en production, son évolution suit&lt;br/&gt;le même cycle ① → ⑩ avec ces &lt;b&gt;particularités&lt;/b&gt; :" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=11;fontColor=#475569;" vertex="1" parent="1">
          <mxGeometry x="1115" y="195" width="460" height="40" as="geometry" />
        </mxCell>

        <!-- Evo point 1 -->
        <mxCell id="evo-1" value="&lt;b style=&quot;color:#9A3412&quot;&gt;⚠ Versioning automatique&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:10px&quot;&gt;Chaque re-déploiement crée une nouvelle version en base. Les instances actives gardent leur version d'origine — prévoir un plan de migration ou un drain avant retrait.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#C2410C;strokeWidth=1;fontSize=11;fontColor=#0F172A;align=left;verticalAlign=top;spacingTop=8;spacingLeft=10;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1115" y="240" width="460" height="75" as="geometry" />
        </mxCell>

        <!-- Evo point 2 -->
        <mxCell id="evo-2" value="&lt;b style=&quot;color:#9A3412&quot;&gt;🔁 Compatibilité descendante&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:10px&quot;&gt;Ne &lt;b&gt;jamais&lt;/b&gt; renommer un &lt;span style=&quot;font-family:monospace&quot;&gt;processDefinitionKey&lt;/span&gt; ou supprimer un &lt;span style=&quot;font-family:monospace&quot;&gt;serviceTask&lt;/span&gt; référencé par des instances actives. Conserver les delegates Java tant qu'une version les utilise (déprécier puis purger).&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#C2410C;strokeWidth=1;fontSize=11;fontColor=#0F172A;align=left;verticalAlign=top;spacingTop=8;spacingLeft=10;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1115" y="325" width="460" height="85" as="geometry" />
        </mxCell>

        <!-- Evo point 3 -->
        <mxCell id="evo-3" value="&lt;b style=&quot;color:#9A3412&quot;&gt;🔒 Sécurité de la REST API&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:10px&quot;&gt;L'API Flowable est &lt;b&gt;exposée par défaut&lt;/b&gt; : imposer Spring Security, restreindre par rôle (ROLE_ADMIN sur /repository), OAuth2/OIDC interne, désactiver basic auth.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#C2410C;strokeWidth=1;fontSize=11;fontColor=#0F172A;align=left;verticalAlign=top;spacingTop=8;spacingLeft=10;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1115" y="420" width="460" height="75" as="geometry" />
        </mxCell>

        <!-- Evo point 4 -->
        <mxCell id="evo-4" value="&lt;b style=&quot;color:#9A3412&quot;&gt;💾 Schéma DB &amp; historique&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:10px&quot;&gt;En prod : &lt;span style=&quot;font-family:monospace&quot;&gt;database-schema-update=false&lt;/span&gt;, migrations contrôlées via Liquibase dédié. Purger / TTL sur &lt;span style=&quot;font-family:monospace&quot;&gt;ACT_HI_*&lt;/span&gt; qui grossit vite.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#C2410C;strokeWidth=1;fontSize=11;fontColor=#0F172A;align=left;verticalAlign=top;spacingTop=8;spacingLeft=10;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1115" y="505" width="460" height="75" as="geometry" />
        </mxCell>

        <!-- Evo point 5 -->
        <mxCell id="evo-5" value="&lt;b style=&quot;color:#9A3412&quot;&gt;📊 Process Façade obligatoire&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:10px&quot;&gt;Exposer une API métier maison plutôt que l'API Flowable native aux consommateurs externes. Protège du couplage et facilite les évolutions internes du moteur.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#C2410C;strokeWidth=1;fontSize=11;fontColor=#0F172A;align=left;verticalAlign=top;spacingTop=8;spacingLeft=10;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1115" y="590" width="460" height="75" as="geometry" />
        </mxCell>

        <!-- Evo point 6 -->
        <mxCell id="evo-6" value="&lt;b style=&quot;color:#9A3412&quot;&gt;🧪 Test de migration systématique&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:10px&quot;&gt;Replay d'instances réelles en recette avant chaque MEP. Vérifier la coexistence de version N et N-1.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#C2410C;strokeWidth=1;fontSize=11;fontColor=#0F172A;align=left;verticalAlign=top;spacingTop=8;spacingLeft=10;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1115" y="675" width="460" height="60" as="geometry" />
        </mxCell>

        <!-- ========== ARROWS BETWEEN STEPS ========== -->

        <!-- Start -> Modélisation -->
        <mxCell id="e-start-s1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#1F2937;strokeWidth=2;endArrow=classic;" edge="1" parent="1" source="s1-start" target="s1-model">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Modélisation -> Revue -->
        <mxCell id="e-s1-s2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#1F2937;strokeWidth=2;endArrow=classic;" edge="1" parent="1" source="s1-model" target="s2-review">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Revue -> Gateway -->
        <mxCell id="e-s2-gw" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#1F2937;strokeWidth=2;endArrow=classic;" edge="1" parent="1" source="s2-review" target="s2-gateway">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Gateway NO -> back to Modélisation -->
        <mxCell id="e-gw-back" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#DC2626;strokeWidth=1.5;endArrow=classic;dashed=1;dashPattern=4 2;fontSize=10;fontColor=#DC2626;labelBackgroundColor=#FAFAFA;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="s2-gateway" target="s1-model">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="705" y="160" />
              <mxPoint x="310" y="160" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e-gw-back-label" value="non · révisions" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;fontColor=#DC2626;labelBackgroundColor=#FAFAFA;fontStyle=1;" connectable="0" vertex="1" parent="e-gw-back">
          <mxGeometry x="-0.3" relative="1" as="geometry">
            <mxPoint as="offset" />
          </mxGeometry>
        </mxCell>

        <!-- Gateway YES -> Integration -->
        <mxCell id="e-gw-s3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#15803D;strokeWidth=2;endArrow=classic;fontSize=10;fontColor=#15803D;labelBackgroundColor=#FAFAFA;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="s2-gateway" target="s3-integrate">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="705" y="320" />
              <mxPoint x="320" y="320" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e-gw-s3-label" value="oui" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;fontColor=#15803D;labelBackgroundColor=#FAFAFA;fontStyle=1;" connectable="0" vertex="1" parent="e-gw-s3">
          <mxGeometry x="-0.7" relative="1" as="geometry">
            <mxPoint as="offset" />
          </mxGeometry>
        </mxCell>

        <!-- Integration -> Test -->
        <mxCell id="e-s3-s4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#1F2937;strokeWidth=2;endArrow=classic;" edge="1" parent="1" source="s3-integrate" target="s4-test">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Test -> MR -->
        <mxCell id="e-s4-s5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#1F2937;strokeWidth=2;endArrow=classic;" edge="1" parent="1" source="s4-test" target="s5-mr">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- MR -> Build (cross-lane) -->
        <mxCell id="e-s5-s6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#1F2937;strokeWidth=2;endArrow=classic;fontSize=10;fontColor=#475569;labelBackgroundColor=#FAFAFA;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="s5-mr" target="s6-build">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="790" y="500" />
              <mxPoint x="310" y="500" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e-s5-s6-label" value="trigger pipeline" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;fontColor=#475569;labelBackgroundColor=#FAFAFA;fontStyle=2;" connectable="0" vertex="1" parent="e-s5-s6">
          <mxGeometry x="-0.5" relative="1" as="geometry">
            <mxPoint as="offset" />
          </mxGeometry>
        </mxCell>

        <!-- Build -> Recette -->
        <mxCell id="e-s6-s7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#1F2937;strokeWidth=2;endArrow=classic;" edge="1" parent="1" source="s6-build" target="s7-recette">
