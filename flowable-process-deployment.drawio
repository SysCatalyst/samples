        </mxCell>

        <!-- Auto-deploy -> Run -->
        <mxCell id="e-s9-s10" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#1F2937;strokeWidth=2;endArrow=classic;" edge="1" parent="1" source="s9-autodeploy" target="s10-run">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Run -> Monitor -->
        <mxCell id="e-s10-s11" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#1F2937;strokeWidth=2;endArrow=classic;" edge="1" parent="1" source="s10-run" target="s11-monitor">
