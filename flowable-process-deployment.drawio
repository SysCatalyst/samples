        <!-- Monitor -> End -->
        <mxCell id="e-s11-end" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#1F2937;strokeWidth=2;endArrow=classic;" edge="1" parent="1" source="s11-monitor" target="end-event">
          <mxGeometry relative="1" as="geometry" />
