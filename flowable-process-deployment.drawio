        <!-- ========== DEV LANE STEPS ========== -->
        <mxCell id="s3-integrate" value="&lt;b&gt;③ Intégration au repo&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:10px&quot;&gt;.bpmn20.xml → &lt;br/&gt;&lt;span style=&quot;font-family:monospace&quot;&gt;src/main/resources/processes/&lt;/span&gt;&lt;br/&gt;+ JavaDelegate, listeners&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1D4ED8;strokeWidth=2;fontSize=11;fontColor=#1E40AF;align=center;verticalAlign=middle;arcSize=10;" vertex="1" parent="1">
