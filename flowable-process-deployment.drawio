        <!-- Recette -> Gateway -->
        <mxCell id="e-s7-gw" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#1F2937;strokeWidth=2;endArrow=classic;" edge="1" parent="1" source="s7-recette" target="s7-gateway">
