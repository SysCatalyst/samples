        <mxCell id="s1-model" value="&lt;b&gt;① Modélisation BPMN&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:10px&quot;&gt;Flowable Modeler / bpmn.io&lt;br/&gt;→ fichier .bpmn20.xml&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#D97706;strokeWidth=2;fontSize=11;fontColor=#92400E;align=center;verticalAlign=middle;arcSize=10;" vertex="1" parent="1">
