        <mxCell id="s2-review" value="&lt;b&gt;② Revue métier&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:10px&quot;&gt;BA + PO valident&lt;br/&gt;scénarios de test&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#D97706;strokeWidth=2;fontSize=11;fontColor=#92400E;align=center;verticalAlign=middle;arcSize=10;" vertex="1" parent="1">
