        <!-- ========== LEGEND / KEY TAKEAWAYS ========== -->
        <mxCell id="legend-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#CBD5E1;strokeWidth=1;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="775" width="1570" height="160" as="geometry" />
        </mxCell>

        <mxCell id="legend-title" value="POINTS CLÉS DE DÉPLOIEMENT" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontStyle=1;fontColor=#6B7280;" vertex="1" parent="1">
          <mxGeometry x="60" y="785" width="400" height="25" as="geometry" />
        </mxCell>

        <!-- Key 1 : auto-deploy classpath -->
        <mxCell id="key-1" value="&lt;b&gt;📦 Le BPMN est packagé dans le JAR&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:10px;color:#475569&quot;&gt;Les fichiers .bpmn20.xml sont versionnés dans Git aux côtés du code Java et embarqués dans l'image Docker. Pas de déploiement séparé du workflow.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#1D4ED8;strokeWidth=1;fontSize=11;fontColor=#0F172A;align=left;verticalAlign=top;spacingTop=8;spacingLeft=10;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="60" y="820" width="370" height="100" as="geometry" />
        </mxCell>

        <!-- Key 2 : auto-config -->
        <mxCell id="key-2" value="&lt;b&gt;🚀 Pas de déploiement manuel du process&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:10px;color:#475569&quot;&gt;Au démarrage du microservice, le starter Spring Boot scanne le classpath et déploie automatiquement chaque .bpmn20.xml dans la table &lt;span style=&quot;font-family:monospace&quot;&gt;ACT_RE_PROCDEF&lt;/span&gt;. Pas d'API à appeler.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#047857;strokeWidth=1;fontSize=11;fontColor=#0F172A;align=left;verticalAlign=top;spacingTop=8;spacingLeft=10;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="450" y="820" width="370" height="100" as="geometry" />
        </mxCell>

        <!-- Key 3 : versioning -->
        <mxCell id="key-3" value="&lt;b&gt;🔀 Coexistence des versions&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:10px;color:#475569&quot;&gt;Flowable gère le versioning : nouvelles instances → version courante, anciennes instances → version d'origine. Permet une migration en douceur, mais oblige à maintenir la rétrocompatibilité du code Java associé.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#CA8A04;strokeWidth=1;fontSize=11;fontColor=#0F172A;align=left;verticalAlign=top;spacingTop=8;spacingLeft=10;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="840" y="820" width="370" height="100" as="geometry" />
        </mxCell>

        <!-- Key 4 : REST exposed -->
        <mxCell id="key-4" value="&lt;b&gt;🔐 REST Flowable exposée d'office&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:10px;color:#475569&quot;&gt;L'auto-configuration expose &lt;span style=&quot;font-family:monospace&quot;&gt;/flowable-rest/*&lt;/span&gt; automatiquement. Sécuriser dès le départ (Spring Security + OIDC), restreindre les endpoints d'admin, et préférer une Process Façade pour les consommateurs externes.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#BE185D;strokeWidth=1;fontSize=11;fontColor=#0F172A;align=left;verticalAlign=top;spacingTop=8;spacingLeft=10;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1230" y="820" width="365" height="100" as="geometry" />
        </mxCell>

        <!-- Footer -->
        <mxCell id="footer" value="Architecture Flowable BPMN · Process de design &amp; déploiement · El Hadi — CPDP team" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#94A3B8;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="40" y="950" width="1500" height="20" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
