    <mxCell id="r13" value="Responds with&#xa;KpiSnapshot [REST JSON]" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#0E5EA3;fontColor=#0E5EA3;fontSize=11;endArrow=block;endFill=1;" edge="1" parent="1" source="query_svc" target="dashboard">
