    <mxCell id="r5" value="event_time epoch millis" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#0E5EA3;fontColor=#0E5EA3;fontSize=11;endArrow=open;dashed=1;" edge="1" parent="1" source="ts_extractor" target="rekey_node">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- rekey_node → agg_node -->
    <mxCell id="r6" value="KGroupedStream by composite key&#xa;[repartition topic auto-created]" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#0E5EA3;fontColor=#0E5EA3;fontSize=11;fontStyle=1;endArrow=block;endFill=1;strokeWidth=2;" edge="1" parent="1" source="rekey_node" target="agg_node">
