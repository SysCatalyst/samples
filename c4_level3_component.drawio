    <!-- source_node → filter_node -->
    <mxCell id="r3" value="KStream&lt;String, EnrichedTx&gt;" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#0E5EA3;fontColor=#0E5EA3;fontSize=11;endArrow=block;endFill=1;" edge="1" parent="1" source="source_node" target="filter_node">
