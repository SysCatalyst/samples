    <mxCell id="r1" value="Kafka poll&#xa;[at-least-once]" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#0E5EA3;fontColor=#0E5EA3;fontSize=11;fontStyle=1;endArrow=block;endFill=1;strokeWidth=2;" edge="1" parent="1" source="topic_in" target="source_node">
      <mxGeometry relative="1" as="geometry" />
