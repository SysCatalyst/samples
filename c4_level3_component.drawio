    <!-- Title -->
    <mxCell id="title" value="C4 Model — Level 3: Component Diagram&#xa;Container: KPI Streams Processor (Kafka Streams / Java)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1;fontColor=#1F3864;" vertex="1" parent="1">
      <mxGeometry x="327" y="20" width="1000" height="55" as="geometry" />
    </mxCell>

    <!-- ═══════════════════════════════════════════════════════
         EXTERNAL ELEMENTS (inputs/outputs)
    ══════════════════════════════════════════════════════ -->

    <mxCell id="topic_in" value="&lt;b&gt;transactions.enriched&lt;/b&gt;&#xa;[Kafka Topic]&#xa;&#xa;Enriched &amp; reconciled transaction&#xa;events. Key = merchant_id." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#999999;strokeColor=#6C6C6C;fontColor=#ffffff;fontSize=12;arcSize=4;" vertex="1" parent="1">
      <mxGeometry x="40" y="420" width="220" height="120" as="geometry" />
    </mxCell>

    <mxCell id="topic_out" value="&lt;b&gt;kpi.updates&lt;/b&gt;&#xa;[Kafka Topic]&#xa;&#xa;KpiSnapshot per (pos_id, date).&#xa;Includes retroactiveCorrection flag." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#999999;strokeColor=#6C6C6C;fontColor=#ffffff;fontSize=12;arcSize=4;" vertex="1" parent="1">
      <mxGeometry x="1390" y="420" width="220" height="120" as="geometry" />
    </mxCell>

    <mxCell id="rocksdb_ext" value="&lt;b&gt;RocksDB State Store&lt;/b&gt;&#xa;kpi-store-pos-date&#xa;&#xa;Embedded KV store.&#xa;Backed by changelog topic." style="shape=mxgraph.flowchart.stored_data;whiteSpace=wrap;html=1;fillColor=#999999;strokeColor=#6C6C6C;fontColor=#ffffff;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="640" y="870" width="240" height="110" as="geometry" />
    </mxCell>

    <!-- ═══════════════════════════════════════════════════════
         KPI STREAMS PROCESSOR BOUNDARY
    ══════════════════════════════════════════════════════ -->

    <mxCell id="boundary" value="KPI Streams Processor [Container Boundary]" style="points=[[0,0],[0.25,0],[0.5,0],[0.75,0],[1,0],[1,0.25],[1,0.5],[1,0.75],[1,1],[0.75,1],[0.5,1],[0.25,1],[0,1],[0,0.75],[0,0.5],[0,0.25]];shape=mxgraph.lean_mapping.electronic_info_flow_edge;html=1;whiteSpace=wrap;fillColor=none;strokeColor=#1168BD;strokeWidth=2;dashed=1;verticalLabelPosition=top;verticalAlign=bottom;fontSize=14;fontStyle=1;fontColor=#1168BD;" vertex="1" parent="1">
      <mxGeometry x="310" y="90" width="1040" height="750" as="geometry" />
    </mxCell>

    <!-- ─── Component 1: Source Node ─── -->
    <mxCell id="source_node" value="&lt;b&gt;Source Node&lt;/b&gt;&#xa;[Component: KStream source]&#xa;&#xa;builder.stream(&quot;transactions.enriched&quot;)&#xa;Consumed.with(enrichedTxSerde)&#xa;  .withTimestampExtractor(...)&#xa;Consumer group: kpi-processor" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1168BD;strokeColor=#0E5EA3;fontColor=#ffffff;fontSize=12;arcSize=4;" vertex="1" parent="1">
      <mxGeometry x="340" y="140" width="300" height="160" as="geometry" />
    </mxCell>

    <!-- ─── Component 2: TransactionEventTimeExtractor ─── -->
    <mxCell id="ts_extractor" value="&lt;b&gt;TransactionEventTimeExtractor&lt;/b&gt;&#xa;[Component: TimestampExtractor]&#xa;&#xa;Reads event_time from payload.&#xa;Falls back to partitionTime if null.&#xa;Anchors all temporal logic on&#xa;business time, not ingestion time." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1168BD;strokeColor=#0E5EA3;fontColor=#ffffff;fontSize=12;arcSize=4;" vertex="1" parent="1">
      <mxGeometry x="700" y="140" width="300" height="160" as="geometry" />
    </mxCell>

    <!-- ─── Component 3: Filter Node ─── -->
    <mxCell id="filter_node" value="&lt;b&gt;Filter Node&lt;/b&gt;&#xa;[Component: KStream.filter]&#xa;&#xa;Discards events where pos_id&#xa;or event_time is null.&#xa;Emits warning metric on drop." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1168BD;strokeColor=#0E5EA3;fontColor=#ffffff;fontSize=12;arcSize=4;" vertex="1" parent="1">
      <mxGeometry x="340" y="360" width="280" height="150" as="geometry" />
    </mxCell>

    <!-- ─── Component 4: ReKey Node ─── -->
    <mxCell id="rekey_node" value="&lt;b&gt;ReKey Node&lt;/b&gt;&#xa;[Component: KStream.selectKey]&#xa;&#xa;Derives business date from event_time&#xa;(atZone UTC → toLocalDate).&#xa;Emits composite key:&#xa;  pos_id + &quot;|&quot; + business_date&#xa;Triggers Kafka repartition." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1168BD;strokeColor=#0E5EA3;fontColor=#ffffff;fontSize=12;arcSize=4;" vertex="1" parent="1">
      <mxGeometry x="700" y="360" width="300" height="180" as="geometry" />
    </mxCell>

    <!-- ─── Component 5: Aggregate Node ─── -->
    <mxCell id="agg_node" value="&lt;b&gt;Aggregate Node&lt;/b&gt;&#xa;[Component: KGroupedStream.aggregate]&#xa;&#xa;Initializer: new PosKpiAccumulator()&#xa;Aggregator: acc.update(tx)&#xa;  — idempotence via processedTxIds set&#xa;  — increments sum+count per status&#xa;  — no window, open KeyValueStore&#xa;State store: kpi-store-pos-date (90d)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1168BD;strokeColor=#0E5EA3;fontColor=#ffffff;fontSize=12;arcSize=4;" vertex="1" parent="1">
      <mxGeometry x="530" y="590" width="340" height="210" as="geometry" />
    </mxCell>

    <!-- ─── Component 6: PosKpiAccumulator ─── -->
    <mxCell id="accumulator" value="&lt;b&gt;PosKpiAccumulator&lt;/b&gt;&#xa;[Component: Aggregation POJO]&#xa;&#xa;Fields (statistical sufficients):&#xa;  approvedAmountSumCents: long&#xa;  approvedCount: long&#xa;  fraudCount, fraudSumCents: long&#xa;  failedCount, totalCount: long&#xa;  processedTxIds: Set&lt;String&gt;&#xa;Derives avg at toSnapshot() time." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0F6E56;strokeColor=#085041;fontColor=#ffffff;fontSize=12;arcSize=4;" vertex="1" parent="1">
      <mxGeometry x="960" y="560" width="320" height="240" as="geometry" />
    </mxCell>

    <!-- ─── Component 7: Snapshot Mapper ─── -->
    <mxCell id="snapshot_mapper" value="&lt;b&gt;Snapshot Mapper&lt;/b&gt;&#xa;[Component: KTable.toStream().map()]&#xa;&#xa;Parses composite key → posId + date.&#xa;Calls acc.toSnapshot(posId, date).&#xa;Sets isRetroactiveCorrection flag&#xa;  (businessDate != today UTC).&#xa;Sets computedAt = Instant.now()." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1168BD;strokeColor=#0E5EA3;fontColor=#ffffff;fontSize=12;arcSize=4;" vertex="1" parent="1">
      <mxGeometry x="960" y="340" width="310" height="190" as="geometry" />
    </mxCell>

    <!-- ─── Component 8: Sink Node ─── -->
    <mxCell id="sink_node" value="&lt;b&gt;Sink Node&lt;/b&gt;&#xa;[Component: KStream.to()]&#xa;&#xa;Produces to kpi.updates.&#xa;Key: composite pos_id|date.&#xa;Serde: KpiSnapshotSerde (JSON/Avro).&#xa;EOS: exactly_once_v2 producer." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1168BD;strokeColor=#0E5EA3;fontColor=#ffffff;fontSize=12;arcSize=4;" vertex="1" parent="1">
      <mxGeometry x="1100" y="140" width="210" height="180" as="geometry" />
    </mxCell>

