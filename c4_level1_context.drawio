    <!-- Payment Processors -->
    <mxCell id="payment_proc" value="&lt;b&gt;Payment Processors&lt;/b&gt;&#xa;[External System]&#xa;&#xa;Visa, Mastercard, local&#xa;acquirers. Produce raw&#xa;transaction authorization events." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#999999;strokeColor=#6C6C6C;fontColor=#ffffff;fontSize=12;fontStyle=0;arcSize=4;" vertex="1" parent="1">
      <mxGeometry x="1100" y="200" width="220" height="140" as="geometry" />
    </mxCell>

    <!-- Fraud Detection Engine -->
