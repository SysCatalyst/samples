    ════════════════════════════════════════════════════════════════ -->

    <mxCell id="kpi_system" value="&lt;b&gt;Real-Time KPI Platform&lt;/b&gt;&#xa;[Software System]&#xa;&#xa;Computes and exposes real-time&#xa;KPIs (total collected, avg basket,&#xa;fraud rate, approval rate) per&#xa;point of sale and business day.&#xa;Handles late event correction." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1168BD;strokeColor=#0E5EA3;fontColor=#ffffff;fontSize=13;fontStyle=0;arcSize=4;verticalAlign=middle;" vertex="1" parent="1">
      <mxGeometry x="590" y="400" width="480" height="180" as="geometry" />
    </mxCell>

